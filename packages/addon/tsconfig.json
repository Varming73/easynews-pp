{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true
  },
  "include": ["src/**/*", "follow-redirects.d.ts"],
  "exclude": ["**/*.test.ts"],
  "references": [
    {
      "path": "../api"
    },
    {
      "path": "../shared"
    }
  ]
}
