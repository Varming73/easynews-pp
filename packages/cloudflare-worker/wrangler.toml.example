name = "easynews-cloudflare-worker"
compatibility_date = "2024-09-23"

compatibility_flags = ["nodejs_compat", "nodejs_compat_populate_process_env"]

[observability]
enabled = true
head_sampling_rate = 1 

[placement]
mode = "smart"

[vars]
PORT = "1337"
EASYNEWS_LOG_LEVEL = "info"
EASYNEWS_SUMMARIZE_LOGS = "false" # IMPORTANT: You must disable summary logging in Cloudflare Workers
CLOUDFLARE = "true" # DO NOT EDIT THIS
CACHE_TTL = "6"
TOTAL_MAX_RESULTS = "500"
MAX_PAGES = "10"
MAX_RESULTS_PER_PAGE = "250"
# Performance tuning (safe defaults; change only if you know what you're doing)
SEARCH_CONCURRENCY = "5" # Title-variant searches run in parallel batches of this size (min 1)
META_FETCH_TIMEOUT_MS = "5000" # Timeout (ms) for metadata lookups (IMDb / Cinemeta / TMDB)
MAX_CACHE_ENTRIES = "1000" # Max entries kept in the in-memory search-results cache
RESOLVE_CACHE_TTL_SECONDS = "300" # How long the /resolve proxy reuses a resolved CDN URL (seconds)
TMDB_API_KEY = "" # Add encrypted value to your Cloudflare worker instance