# Port configuration
PORT=1337

# Logging configuration
EASYNEWS_LOG_LEVEL=info # Options: error, warn, info, debug, silly, or silent
EASYNEWS_SUMMARIZE_LOGS=true # To group similar debug logs and reduce log volume

# Streaming / Security
# Stream URLs are routed through this addon's /resolve proxy so your Easynews
# credentials are never embedded in the URL handed to the player. Installs created
# via the configuration page already carry their own base URL. Set ADDON_BASE_URL
# to the addon's public origin to cover older installs whose saved config predates
# this (otherwise they will see a "reconfigure" message instead of streams).
# ADDON_BASE_URL=https://your-addon.example.com
#
# INSECURE escape hatch: when true, restores the legacy behavior of embedding your
# Easynews username/password directly in stream URLs. Leave false/unset.
# ALLOW_INSECURE_CREDENTIAL_URLS=false

# API Settings
MAX_RESULTS_PER_PAGE=250 # Easynews API Limit = 250 - leave at the default if you don't know what you're doing
MAX_PAGES=10 # Max Pages to crawl - leave at the default if you don't know what you're doing
TOTAL_MAX_RESULTS=500 # Max results to crawl in total - lower means faster response times
CACHE_TTL=6 # Search-results cache time in hours (6 = 6 hours cache time)

# Performance tuning (safe defaults; change only if you know what you're doing)
SEARCH_CONCURRENCY=5 # Title-variant searches run in parallel batches of this size (min 1)
META_FETCH_TIMEOUT_MS=5000 # Timeout (ms) for metadata lookups (IMDb / Cinemeta / TMDB)
MAX_CACHE_ENTRIES=1000 # Max entries kept in the in-memory search-results cache
RESOLVE_CACHE_TTL_SECONDS=300 # How long the /resolve proxy reuses a resolved CDN URL (seconds)

# TMBD Settings (to search for translated titles)
TMDB_API_KEY=api_key

# Chatwood Live Chat Settings
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=https://support.example.com
CHATWOOT_WEBSITE_TOKEN=xxxx-xxxx-xxxx-xxxx